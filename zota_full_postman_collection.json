{
  "info": {
    "name": "Zota Backend Full API Collection",
    "description": "Complete Postman collection for Zota Backend APIs. Includes all microservices with pre-configured variables for both production (via Nginx) and development (direct service) access.\n\nTo use this collection:\n1. Import this file into Postman\n2. Edit collection variables:\n   - For Production: Set 'domain' to your actual domain (e.g., api.yourdomain.com) and 'protocol' to https\n   - For Development: Use the 'local*BaseUrl' variables which point directly to services on localhost\n3. The nginx paths (/auth/, /bop/, /wallet/, etc.) are automatically appended to the domain\n4. All requests are pre-configured to use the appropriate base URLs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0",
    "_postman_id": "zota-full-collection"
  },
  "variable": [
    {
      "key": "domain",
      "value": "yourdomain.com"
    },
    {
      "key": "protocol",
      "value": "https"
    },
    {
      "key": "baseUrl",
      "value": "https://yourdomain.com"
    },
    {
      "key": "authBaseUrl",
      "value": "{{protocol}}://{{domain}}/auth"
    },
    {
      "key": "baseOpsBaseUrl",
      "value": "{{protocol}}://{{domain}}/bop"
    },
    {
      "key": "devicesBaseUrl",
      "value": "{{protocol}}://{{domain}}/devices"
    },
    {
      "key": "mikrotikBaseUrl",
      "value": "{{protocol}}://{{domain}}/mikrotik"
    },
    {
      "key": "radiusBaseUrl",
      "value": "{{protocol}}://{{domain}}/radius"
    },
    {
      "key": "walletBaseUrl",
      "value": "{{protocol}}://{{domain}}/wallet"
    },
    {
      "key": "localAuthBaseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "localBaseOpsBaseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "localMikrotikBaseUrl",
      "value": "http://localhost:3003"
    },
    {
      "key": "localWalletBaseUrl",
      "value": "http://localhost:3002"
    },
    {
      "key": "localDevicesBaseUrl",
      "value": "http://localhost:3004"
    },
    {
      "key": "localRadiusBaseUrl",
      "value": "http://localhost:3005"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "clientId",
      "value": "1"
    },
    {
      "key": "routerId",
      "value": "1"
    },
    {
      "key": "walletId",
      "value": "1"
    },
    {
      "key": "agentId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"John Admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"Admin\",\n  \"client_id\": \"{{clientId}}\"\n}"
            },
            "url": {
              "raw": "{{authBaseUrl}}/auth/register",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\",\n  \"client_id\": \"{{clientId}}\"\n}" },
            "url": { "raw": "{{authBaseUrl}}/auth/login", "host": ["{{authBaseUrl}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"verificationCode\": \"123456\",\n  \"client_id\": \"{{clientId}}\"\n}" },
            "url": { "raw": "{{authBaseUrl}}/auth/verify-email", "host": ["{{authBaseUrl}}"], "path": ["auth","verify-email"] }
          }
        },
        {
          "name": "Resend Verification Code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"client_id\": \"{{clientId}}\"\n}" },
            "url": { "raw": "{{authBaseUrl}}/auth/resend-verification-code", "host": ["{{authBaseUrl}}"], "path": ["auth","resend-verification-code"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"client_id\": \"{{clientId}}\"\n}" },
            "url": { "raw": "{{authBaseUrl}}/auth/forgot-password", "host": ["{{authBaseUrl}}"], "path": ["auth","forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"resetToken\": \"token-from-email\",\n  \"newPassword\": \"NewPass123!\",\n  \"client_id\": \"{{clientId}}\"\n}" },
            "url": { "raw": "{{authBaseUrl}}/auth/reset-password", "host": ["{{authBaseUrl}}"], "path": ["auth","reset-password"] }
          }
        },
        {
          "name": "Add Agent (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"fullname\": \"Agent One\",\n  \"email\": \"agent@example.com\",\n  \"password\": \"AgentPass123!\",\n  \"client_id\": \"{{clientId}}\"\n}" },
            "url": { "raw": "{{authBaseUrl}}/auth/add-agent", "host": ["{{authBaseUrl}}"], "path": ["auth","add-agent"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"fullname\": \"New Name\",\n  \"currentPassword\": \"Password123!\",\n  \"newPassword\": \"NewPass123!\",\n  \"client_id\": \"{{clientId}}\"\n}" },
            "url": { "raw": "{{authBaseUrl}}/auth/update-profile", "host": ["{{authBaseUrl}}"], "path": ["auth","update-profile"] }
          }
        }
      ]
    },
    {
      "name": "Base Operations Service",
      "item": [
        {
          "name": "Clients - Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"businessName\": \"My Business\",\n  \"adminFullName\": \"Admin Name\",\n  \"adminEmail\": \"admin@example.com\",\n  \"adminPassword\": \"Password123!\",\n  \"contact\": \"+123456789\"\n}" },
            "url": { "raw": "{{baseOpsBaseUrl}}/clients", "host": ["{{baseOpsBaseUrl}}"], "path": ["clients"] }
          }
        },
        { "name": "Clients - List", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/clients", "host": ["{{baseOpsBaseUrl}}"], "path": ["clients"] } } },
        { "name": "Clients - Get", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/clients/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["clients","1"] } } },
        { "name": "Clients - Update Status", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"status\": \"Active\"\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/clients/1/status", "host": ["{{baseOpsBaseUrl}}"], "path": ["clients","1","status"] } } },
        { "name": "Clients - Report", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/clients/1/report", "host": ["{{baseOpsBaseUrl}}"], "path": ["clients","1","report"] } } },

        { "name": "Packages - Create", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"period\": 2592000,\n  \"title\": \"Monthly\",\n  \"price\": 29.99,\n  \"agentComissionPercentage\": 10.5\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/packages", "host": ["{{baseOpsBaseUrl}}"], "path": ["packages"] } } },
        { "name": "Packages - List", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/packages", "host": ["{{baseOpsBaseUrl}}"], "path": ["packages"] } } },
        { "name": "Packages - Get", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/packages/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["packages","1"] } } },
        { "name": "Packages - Update", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"period\": 2592000,\n  \"title\": \"Updated Plan\",\n  \"price\": 39.99,\n  \"agentComissionPercentage\": 12.0\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/packages/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["packages","1"] } } },
        { "name": "Packages - Delete", "request": { "method": "DELETE", "url": { "raw": "{{baseOpsBaseUrl}}/packages/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["packages","1"] } } },

        { "name": "Vouchers - Create", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"length\":10,\n \"prefix\": \"ZT\",\n \"count\":1,\n  \"package_id\": 1,\n  \"client_id\": {{clientId}}\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/vouchers", "host": ["{{baseOpsBaseUrl}}"], "path": ["vouchers"] } } },
        { "name": "Vouchers - By Client", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/vouchers/client/{{clientId}}", "host": ["{{baseOpsBaseUrl}}"], "path": ["vouchers","client","{{clientId}}"] } } },
        { "name": "Vouchers - By Code", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/vouchers/code/VOUCHER123", "host": ["{{baseOpsBaseUrl}}"], "path": ["vouchers","code","VOUCHER123"] } } },
        { "name": "Vouchers - Update Status", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"status\": \"used\"\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/vouchers/1/status", "host": ["{{baseOpsBaseUrl}}"], "path": ["vouchers","1","status"] } } },
        { "name": "Vouchers - Delete", "request": { "method": "DELETE", "url": { "raw": "{{baseOpsBaseUrl}}/vouchers/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["vouchers","1"] } } },

        { "name": "Adverts - Create", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"description\": \"Promo\",\n  \"media\": \"https://example.com/image.jpg\",\n  \"client_id\": {{clientId}},\n  \"duration\": 604800\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/adverts", "host": ["{{baseOpsBaseUrl}}"], "path": ["adverts"] } } },
        { "name": "Adverts - By Client", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/adverts/client/{{clientId}}", "host": ["{{baseOpsBaseUrl}}"], "path": ["adverts","client","{{clientId}}"] } } },
        { "name": "Adverts - Active By Client", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/adverts/client/{{clientId}}/active", "host": ["{{baseOpsBaseUrl}}"], "path": ["adverts","client","{{clientId}}","active"] } } },
        { "name": "Adverts - Get", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/adverts/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["adverts","1"] } } },
        { "name": "Adverts - Update", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated Promo\",\n  \"media\": \"https://example.com/new-image.jpg\",\n  \"duration\": 604800\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/adverts/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["adverts","1"] } } },
        { "name": "Adverts - Delete", "request": { "method": "DELETE", "url": { "raw": "{{baseOpsBaseUrl}}/adverts/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["adverts","1"] } } },

        { "name": "RouterDevices - Create", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Main Router\",\n  \"macAddress\": \"00:11:22:33:44:55\",\n  \"ipAddress\": \"192.168.1.1\",\n  \"client_id\": {{clientId}}\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/router-devices", "host": ["{{baseOpsBaseUrl}}"], "path": ["router-devices"] } } },
        { "name": "RouterDevices - By Client", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/router-devices/client/{{clientId}}", "host": ["{{baseOpsBaseUrl}}"], "path": ["router-devices","client","{{clientId}}"] } } },
        { "name": "RouterDevices - Get", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/router-devices/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["router-devices","1"] } } },
        { "name": "RouterDevices - Update", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Router\",\n  \"macAddress\": \"00:11:22:33:44:55\",\n  \"ipAddress\": \"192.168.1.2\"\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/router-devices/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["router-devices","1"] } } },
        { "name": "RouterDevices - Delete", "request": { "method": "DELETE", "url": { "raw": "{{baseOpsBaseUrl}}/router-devices/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["router-devices","1"] } } },

        { "name": "Devices - Create", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"macAddress\": \"AA:BB:CC:DD:EE:FF\",\n  \"voucher_id\": 1\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/devices", "host": ["{{baseOpsBaseUrl}}"], "path": ["devices"] } } },
        { "name": "Devices - By Client", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/devices/client/{{clientId}}", "host": ["{{baseOpsBaseUrl}}"], "path": ["devices","client","{{clientId}}"] } } },
        { "name": "Devices - By Voucher", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/devices/voucher/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["devices","voucher","1"] } } },
        { "name": "Devices - Get", "request": { "method": "GET", "url": { "raw": "{{baseOpsBaseUrl}}/devices/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["devices","1"] } } },
        { "name": "Devices - Update Expiry", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"expiresAt\": \"2026-12-31T23:59:59Z\"\n}" }, "url": { "raw": "{{baseOpsBaseUrl}}/devices/1/expiry", "host": ["{{baseOpsBaseUrl}}"], "path": ["devices","1","expiry"] } } },
        { "name": "Devices - Delete", "request": { "method": "DELETE", "url": { "raw": "{{baseOpsBaseUrl}}/devices/1", "host": ["{{baseOpsBaseUrl}}"], "path": ["devices","1"] } } }
      ]
    },
    {
      "name": "MikroTik Service",
      "item": [
        {
          "name": "Router Management",
          "item": [
            { "name": "Register Router", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Main Router\",\n  \"ipAddress\": \"192.168.1.1\",\n  \"apiPort\": 8728,\n  \"apiUser\": \"api_user\",\n  \"apiPassword\": \"api_password\",\n  \"client_id\": {{clientId}}\n}" }, "url": { "raw": "{{mikrotikBaseUrl}}/routers", "host": ["{{mikrotikBaseUrl}}"], "path": ["routers"] } } },
            { "name": "Get Router", "request": { "method": "GET", "url": { "raw": "{{mikrotikBaseUrl}}/routers/{{routerId}}", "host": ["{{mikrotikBaseUrl}}"], "path": ["routers", "{{routerId}}"] } } },
            { "name": "Test Connection", "request": { "method": "POST", "url": { "raw": "{{mikrotikBaseUrl}}/routers/{{routerId}}/test", "host": ["{{mikrotikBaseUrl}}"], "path": ["routers", "{{routerId}}", "test"] } } },
            { "name": "Get Client Routers", "request": { "method": "GET", "url": { "raw": "{{mikrotikBaseUrl}}/routers/client/{{clientId}}", "host": ["{{mikrotikBaseUrl}}"], "path": ["routers", "client", "{{clientId}}"] } } }
          ]
        },
        {
          "name": "Hotspot Users",
          "item": [
            { "name": "Create Hotspot User", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"voucherCode\": \"VOUCHER123ABC\",\n  \"client_id\": {{clientId}},\n  \"router_id\": {{routerId}},\n  \"expiresAt\": \"2026-03-22T00:00:00Z\"\n}" }, "url": { "raw": "{{mikrotikBaseUrl}}/hotspot/users", "host": ["{{mikrotikBaseUrl}}"], "path": ["hotspot", "users"] } } },
            { "name": "Get Hotspot User", "request": { "method": "GET", "url": { "raw": "{{mikrotikBaseUrl}}/hotspot/users/{{userId}}", "host": ["{{mikrotikBaseUrl}}"], "path": ["hotspot", "users", "{{userId}}"] } } },
            { "name": "Get User by Voucher", "request": { "method": "GET", "url": { "raw": "{{mikrotikBaseUrl}}/hotspot/users/voucher/VOUCHER123ABC", "host": ["{{mikrotikBaseUrl}}"], "path": ["hotspot", "users", "voucher", "VOUCHER123ABC"] } } },
            { "name": "Disable User", "request": { "method": "POST", "url": { "raw": "{{mikrotikBaseUrl}}/hotspot/users/{{userId}}/disable", "host": ["{{mikrotikBaseUrl}}"], "path": ["hotspot", "users", "{{userId}}", "disable"] } } }
          ]
        },
        {
          "name": "Sessions",
          "item": [
            { "name": "Record Session", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"hotspotUser_id\": {{userId}},\n  \"router_id\": {{routerId}},\n  \"ipAddress\": \"192.168.1.100\",\n  \"macAddress\": \"AA:BB:CC:DD:EE:FF\",\n  \"uploadBytes\": 0,\n  \"downloadBytes\": 0\n}" }, "url": { "raw": "{{mikrotikBaseUrl}}/sessions", "host": ["{{mikrotikBaseUrl}}"], "path": ["sessions"] } } },
            { "name": "End Session", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"uploadBytes\": 1000000,\n  \"downloadBytes\": 5000000\n}" }, "url": { "raw": "{{mikrotikBaseUrl}}/sessions/1/end", "host": ["{{mikrotikBaseUrl}}"], "path": ["sessions", "1", "end"] } } },
            { "name": "Get Active Sessions", "request": { "method": "GET", "url": { "raw": "{{mikrotikBaseUrl}}/sessions/router/{{routerId}}/active", "host": ["{{mikrotikBaseUrl}}"], "path": ["sessions", "router", "{{routerId}}", "active"] } } }
          ]
        },
        {
          "name": "Portal",
          "item": [
            { "name": "Redeem Voucher Page", "request": { "method": "GET", "url": { "raw": "{{mikrotikBaseUrl}}/portal/redeem.html", "host": ["{{mikrotikBaseUrl}}"], "path": ["portal", "redeem.html"] } } },
            { "name": "Login Page", "request": { "method": "GET", "url": { "raw": "{{mikrotikBaseUrl}}/portal/login.html", "host": ["{{mikrotikBaseUrl}}"], "path": ["portal", "login.html"] } } }
          ]
        }
      ]
    },
    {
      "name": "Wallet Service",
      "item": [
        {
          "name": "Wallet Management",
          "item": [
            { "name": "Create Wallet", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"ownerType\": \"Client\",\n  \"clientId\": {{clientId}},\n  \"phone\": \"+256701234567\"\n}" }, "url": { "raw": "{{walletBaseUrl}}/wallets", "host": ["{{walletBaseUrl}}"], "path": ["wallets"] } } },
            { "name": "Get Wallet Balance", "request": { "method": "GET", "url": { "raw": "{{walletBaseUrl}}/wallets/{{walletId}}/balance", "host": ["{{walletBaseUrl}}"], "path": ["wallets", "{{walletId}}", "balance"] } } },
            { "name": "Get Transaction History", "request": { "method": "GET", "url": { "raw": "{{walletBaseUrl}}/wallets/{{walletId}}/transactions?limit=50", "host": ["{{walletBaseUrl}}"], "path": ["wallets", "{{walletId}}", "transactions"], "query": [{ "key": "limit", "value": "50" }] } } }
          ]
        },
        {
          "name": "Withdrawals",
          "item": [
            { "name": "Initiate Withdrawal", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"walletId\": {{walletId}},\n  \"amount\": 50000,\n  \"phone\": \"+256701234567\",\n  \"provider\": \"MTN\"\n}" }, "url": { "raw": "{{walletBaseUrl}}/withdrawals", "host": ["{{walletBaseUrl}}"], "path": ["withdrawals"] } } },
            { "name": "Get Withdrawal Status", "request": { "method": "GET", "url": { "raw": "{{walletBaseUrl}}/withdrawals/1", "host": ["{{walletBaseUrl}}"], "path": ["withdrawals", "1"] } } },
            { "name": "Get Wallet Withdrawals", "request": { "method": "GET", "url": { "raw": "{{walletBaseUrl}}/withdrawals/wallet/{{walletId}}", "host": ["{{walletBaseUrl}}"], "path": ["withdrawals", "wallet", "{{walletId}}"] } } }
          ]
        },
        {
          "name": "Purchases",
